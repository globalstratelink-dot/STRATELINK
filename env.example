# Configuration Nodemailer pour Stratelink Global
# Remplacez les valeurs par vos propres informations

# Compte Gmail principal (celui qui envoie les emails)
GMAIL_USER=globalstratelink@gmail.com

# Mot de passe d'application Google (16 caractères sans espaces)
# IMPORTANT: Ne pas utiliser votre mot de passe Gmail normal
# Créez un mot de passe d'application dans les paramètres de sécurité Google
# ⚠️ NE JAMAIS COMMITTER CE FICHIER AVEC UN VRAI MOT DE PASSE
GMAIL_APP_PASSWORD=your_app_password_here

# Email de destination (où recevoir les messages de contact)
TO_EMAIL=Contact@stratelink-global.com

# Configuration SMTP (optionnel, utilise Gmail par défaut)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Configuration de l'entreprise
COMPANY_NAME=Stratelink Global
COMPANY_WEBSITE=https://stratelinkglobal.com

# Configuration des emails
EMAIL_SUBJECT_PREFIX=Nouveau message de contact - Stratelink Global
REPLY_TO_EMAIL=Contact@stratelink-global.com

# Configuration de sécurité
NODE_ENV=production

# Mot de passe admin pour /adminAbdelhamid (gestion des services B2B)
CATALOGUE_ADMIN_PASSWORD=your_secure_admin_password

# Supabase (recommandé — sauvegarde catalogue fiable en production)
# 1. Créez un projet gratuit sur https://supabase.com
# 2. Exécutez le SQL dans supabase/catalogue-setup.sql et supabase/form-notifications-setup.sql
# 3. Storage → New bucket → nom: catalogue-images → Public: ON
# 4. Project Settings → API → copiez URL + service_role key (secret)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Catalogue Netlify Blobs (fallback si Supabase non configuré)
# SITE_ID est fourni automatiquement par Netlify (ne pas l'ajouter manuellement).
# Ajoutez seulement ce token :
# https://app.netlify.com/user/applications#personal-access-tokens
NETLIFY_AUTH_TOKEN=your_netlify_personal_access_token

# Cloudflare Turnstile (anti-spam formulaires contact + qualification)
# Créez des clés sur https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Optionnel : pare-feu applicatif (WAF) — activez Cloudflare sur stratelink-global.com
# https://www.cloudflare.com/

# ============================================================================
# INSTRUCTIONS POUR CRÉER UN MOT DE PASSE D'APPLICATION GOOGLE
# ============================================================================

# 1. Allez sur https://myaccount.google.com/security
# 2. Activez la validation en 2 étapes si ce n'est pas déjà fait
# 3. Cliquez sur "Mots de passe des applications"
# 4. Sélectionnez "Autre (nom personnalisé)"
# 5. Nommez-le: "Stratelink Global - Nodemailer"
# 6. Copiez le mot de passe généré (16 caractères)
# 7. Collez-le dans GMAIL_APP_PASSWORD ci-dessus

# ============================================================================
# SÉCURITÉ
# ============================================================================

# ✅ Utilisez UNIQUEMENT un mot de passe d'application
# ❌ N'utilisez JAMAIS votre mot de passe principal Gmail
# ✅ Le mot de passe d'application est sécurisé et peut être révoqué
# ✅ Limitez l'accès à ce fichier .env.local 